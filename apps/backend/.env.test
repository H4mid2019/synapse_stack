# End to end runs. Authentication stays fully enabled; these point the backend
# at the local token issuer in scripts/fake_auth0.py instead of Auth0.
AUTH0_DOMAIN=localhost:9999
AUTH0_AUDIENCE=synapse-api
AUTH0_ISSUER=http://localhost:9999/
AUTH0_JWKS_URL=http://localhost:9999/.well-known/jwks.json
AUTH0_USERINFO_URL=http://localhost:9999/userinfo
